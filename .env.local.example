# Painel Next.js — copiar para `.env.local` (não commitar; ver `.gitignore`)
# Valores abaixo são placeholders; substitua pelos seus.

API_URL=<http://localhost:8000>
API_KEY=<same-as-backend-API_KEY>
# Gerar hash: node -e "console.log(require('bcryptjs').hashSync('sua_senha',10))"
ADMIN_PASSWORD=<bcrypt-hash>
NEXTAUTH_SECRET=<random-string-minimum-32-characters>
NEXTAUTH_URL=<http://localhost:3000>

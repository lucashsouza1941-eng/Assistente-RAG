# Painel Next.js — copie para .env.local (nao commitar)
# API FastAPI (apenas servidor Next; nao expor no browser)
API_URL=http://localhost:8000
API_KEY=sua_api_key_aqui
# Hash bcrypt da senha do painel (gerar: node -e "console.log(require('bcryptjs').hashSync('sua_senha',10))")
ADMIN_PASSWORD=$2b$10$coloque_aqui_o_hash_bcrypt
NEXTAUTH_SECRET=string_aleatoria_minimo_32_caracteres
NEXTAUTH_URL=http://localhost:3000

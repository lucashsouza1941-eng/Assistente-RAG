# =============================================================================
# OdontoBot — variáveis de ambiente (EXEMPLO)
# =============================================================================
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite `.env` nem chaves verdadeiras — use apenas este arquivo como modelo.
#
# Referência: `src/config.py`, `docker-compose.yml`, `src/tests/conftest.py`,
# painel Next.js (`.env.local` — ver secção no fim).
# =============================================================================

# --- HTTP / CORS ---
# Origens permitidas para CORS (lista separada por vírgula).
ALLOWED_ORIGINS=<http://localhost:3000>

# --- Base de dados (PostgreSQL + pgvector) ---
# URL async SQLAlchemy. No Docker Compose (`app`, `worker`), use hostname `postgres`.
DATABASE_URL=<postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE_NAME>

# --- Redis (cache, rate limit, fila ARQ, métricas) ---
# No Docker Compose, use hostname `redis`.
REDIS_URL=<redis://HOST:6379/0>

# --- OpenAI ---
OPENAI_API_KEY=<sk-your-openai-api-key>

# --- MinIO (S3-compatible; documentos para indexação) ---
# No Docker Compose, endpoint típico na rede interna: `minio:9000`.
# Também referenciado em `docker-compose.yml` (serviços `app`, `worker`, `cleanup-worker`, `minio`).
MINIO_ENDPOINT=<minio:9000>
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>
MINIO_BUCKET=<documents>

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_ACCESS_TOKEN=<graph-api-long-lived-token>
WHATSAPP_PHONE_NUMBER_ID=<whatsapp-business-phone-number-id>
WHATSAPP_VERIFY_TOKEN=<custom-string-for-webhook-get-verification>
WHATSAPP_APP_SECRET=<meta-app-secret-for-webhook-hmac>

# --- Segurança interna da API ---
# Salt para hash SHA-256 de identificadores (valor longo e aleatório).
HASH_SALT=<random-long-salt-do-not-reuse>
# Rotas administrativas e `/metrics`: cabeçalho `X-API-Key`. Mesmo valor no painel (`API_KEY`).
API_KEY=<random-api-key-for-admin-routes>

# --- URL pública da API (opcional) ---
# Usada para montar o URL do webhook WhatsApp no painel (`GET /whatsapp/admin/connection`).
# Ex.: https://api.sua-clinica.com — sem barra final.
PUBLIC_API_BASE_URL=<https://api.example.com>

# --- Cifragem de segredos WhatsApp em settings (Fernet) ---
# Obrigatório: tokens `whatsapp.access_token` e `whatsapp.verify_token` são guardados cifrados na coluna JSON `settings.value`.
# Gere uma chave: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=<fernet-key-base64-placeholder>

# --- Aplicação (opcionais; têm defaults em `src/config.py`) ---
CLINIC_NAME=<Nome da clínica>
ESCALATION_THRESHOLD=<0.70>
# Atrás de proxy reverso confiável (ex.: IP real no rate limit).
TRUST_PROXY=<false>
RATE_LIMIT_GLOBAL_PER_MINUTE=<100>
RATE_LIMIT_ADMIN_PER_MINUTE=<30>
RATE_LIMIT_WEBHOOK_PER_MINUTE=<120>
LOG_LEVEL=<INFO>
ENVIRONMENT=<development>
SERVICE_NAME=<odontobot-api>
SERVICE_VERSION=<0.1.0>

# =============================================================================
# Testes (pytest local + `docker-compose.test.yml`)
# =============================================================================
TEST_DATABASE_URL=<postgresql+asyncpg://USER:PASSWORD@localhost:5433/test_odontobot>
TEST_REDIS_URL=<redis://localhost:6380/0>

# =============================================================================
# Painel Next.js — usar ficheiro `.env.local` na raiz (não commitar)
# =============================================================================
# Requisito local: Node.js 20+ (Next.js 16; mesmo major que o CI e o `Dockerfile.frontend`).
# Variáveis abaixo são lidas em runtime no servidor (Route Handlers, auth).
# Não existem `NEXT_PUBLIC_*` no código atual do painel; não exponha segredos no cliente.
#
# API_URL=<http://localhost:8000>
# API_KEY=<mesmo-valor-que-API_KEY-do-backend>
# ADMIN_PASSWORD=<hash-bcrypt-da-senha-do-painel>
# NEXTAUTH_SECRET=<string-aleatória-mín-32-caracteres>
# NEXTAUTH_URL=<http://localhost:3000>
#
# Docker Compose (`frontend`): injeta API_URL fixo a `http://app:8000`, e `API_KEY`,
# `ADMIN_PASSWORD`, `NEXTAUTH_SECRET`, `NEXTAUTH_URL` a partir do `.env` da máquina host
# (defina essas variáveis no `.env` antes de `docker compose up`).
# =============================================================================

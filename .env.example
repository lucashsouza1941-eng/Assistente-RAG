# =============================================================================
# OdontoBot — variáveis de ambiente (EXEMPLO)
# =============================================================================
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite `.env` nem chaves verdadeiras — use apenas este arquivo como modelo.
#
# Referência de código: `src/config.py` (backend), `docker-compose.yml`, testes em
# `src/tests/conftest.py`, painel Next.js (`.env.local`, ver secção no fim).
# =============================================================================

# --- HTTP / CORS ---
# Origens permitidas para CORS (lista separada por vírgula). Ex.: http://localhost:3000
CORS_ORIGINS=<http://localhost:3000>

# --- Base de dados (PostgreSQL + pgvector) ---
# URL async SQLAlchemy. No Docker Compose, o host costuma ser `postgres`.
DATABASE_URL=<postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE_NAME>

# --- Redis (cache, rate limit, fila ARQ) ---
# No Docker Compose, o host costuma ser `redis`.
REDIS_URL=<redis://HOST:6379/0>

# --- OpenAI ---
OPENAI_API_KEY=<sk-your-openai-api-key>

# --- MinIO (S3-compatible; bucket de documentos para indexação) ---
# No Docker Compose, o endpoint costuma ser `minio:9000` (rede interna).
MINIO_ENDPOINT=<minio:9000>
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>
MINIO_BUCKET=<documents>

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_ACCESS_TOKEN=<graph-api-long-lived-token>
WHATSAPP_PHONE_NUMBER_ID=<whatsapp-business-phone-number-id>
WHATSAPP_VERIFY_TOKEN=<custom-string-for-webhook-get-verification>
WHATSAPP_APP_SECRET=<meta-app-secret-for-webhook-hmac>

# --- Segurança interna da API ---
# Salt para hash SHA-256 de identificadores (use valor longo e aleatório).
HASH_SALT=<random-long-salt-do-not-reuse>
# Chave para rotas administrativas (cabeçalho `X-API-Key`). Mesma lógica no painel.
API_KEY=<random-api-key-for-admin-routes>

# --- Aplicação (opcionais; têm defaults no código) ---
CLINIC_NAME=<Nome da clínica>
ESCALATION_THRESHOLD=<0.70>
# Atrás de proxy reverso confiável (ex.: para IP correto no rate limit)
TRUST_PROXY=<false>
LOG_LEVEL=<INFO>
ENVIRONMENT=<development>
SERVICE_NAME=<odontobot-api>
SERVICE_VERSION=<0.1.0>
# URL pública da API (ex.: https://api.sua-clinica.com) — usada no painel para mostrar o URL do webhook WhatsApp.
PUBLIC_API_BASE_URL=<https://api.example.com>

# =============================================================================
# Testes (pytest local + `docker-compose.test.yml`)
# =============================================================================
TEST_DATABASE_URL=<postgresql+asyncpg://USER:PASSWORD@localhost:5433/test_odontobot>
TEST_REDIS_URL=<redis://localhost:6380/0>

# =============================================================================
# Painel Next.js (ficheiro separado: `.env.local` na raiz do repo)
# Não coloque estes valores no bundle do browser — apenas server-side.
# Copie de `.env.local.example` ou defina:
#
# API_URL=<http://localhost:8000>
# API_KEY=<same-as-API_KEY-above>
# ADMIN_PASSWORD=<bcrypt-hash-of-panel-password>
# NEXTAUTH_SECRET=<random-string-min-32-chars>
# NEXTAUTH_URL=<http://localhost:3000>
#
# Docker Compose (`frontend`) pode injetar API_URL, API_KEY, ADMIN_PASSWORD, NEXTAUTH_*.
# =============================================================================

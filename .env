# Docker: hostnames postgres / redis. Para API no host, use localhost no DATABASE_URL e REDIS_URL.
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/odontobot
REDIS_URL=redis://redis:6379/0

# OpenAI — crie em https://platform.openai.com/api-keys (cole a chave completa que começa com sk-...)
OPENAI_API_KEY=sk-replace-me-at-openai-platform

# WhatsApp Cloud API (Meta) — App Dashboard: https://developers.facebook.com/apps
# Access token: Graph API / WhatsApp > API Setup (temporário ou permanente conforme a app)
WHATSAPP_ACCESS_TOKEN=replace-me-meta-graph-token
# ID do número WhatsApp Business (só dígitos, ex.: 123456789012345)
WHATSAPP_PHONE_NUMBER_ID=replace-me-phone-number-id
# Segredo do app (App settings > Basic) — usado para validar assinatura do webhook
WHATSAPP_APP_SECRET=replace-me-meta-app-secret

# Token que você define e cola no Meta no campo "Verify token" do webhook (deve coincidir)
WHATSAPP_VERIFY_TOKEN=wl2rbaOkDU80M53jxkxfX3pVU5n2LeND

# Gerados automaticamente — não commite este ficheiro se contiver chaves reais
HASH_SALT=7b55652b05e62a8fe29580b4196f02c1
API_KEY=B_9OTBWQAZbEHDsaVB2C6Spv9L3ZKAkTbCtkBh86sTI

CLINIC_NAME=Clinica OdontoVida
ESCALATION_THRESHOLD=0.70
LOG_LEVEL=INFO
ENVIRONMENT=development
SERVICE_NAME=odontobot-api
SERVICE_VERSION=0.1.0
TRUST_PROXY=false

